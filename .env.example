# 复制本文件为 .env，填入你自己的 Key
# cp .env.example .env

# 火山方舟 LLM（DeepSeek）API Key
# 获取地址：https://console.volcengine.com/ark
ARK_API_KEY=your_ark_api_key_here

# 火山语音 Key（TTS 语音合成 + STT 语音识别）
# 获取地址：https://console.volcengine.com/speech/service/8
VOLCANO_SPEECH_KEY=your_volcano_speech_key_here

# Tavily 联网搜索 API Key（用于岗位信息检索）
# 获取地址：https://app.tavily.com
TAVILY_API_KEY=your_tavily_api_key_here

# 后端公网地址（由 start.sh 自动写入，无需手动填）
BACKEND_URL=http://localhost:8000
